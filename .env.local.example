NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

FIRECRAWL_API_KEY=fc-your-key-here
CRON_SECRET=a-long-random-secret-string

# Tier 1 dashboard gate (leave both unset in dev to disable the gate).
# DASHBOARD_ACCESS_CODE  — short passcode you share with invited waitlist users.
# DASHBOARD_ACCESS_SIGNATURE — opaque cookie value set on successful entry;
#                              rotate it to force every user to re-enter the code.
DASHBOARD_ACCESS_CODE=change-me-shared-passcode
DASHBOARD_ACCESS_SIGNATURE=change-me-to-a-long-random-string
