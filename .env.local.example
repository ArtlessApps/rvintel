# ── Supabase ─────────────────────────────────────────────────────────────────
# Required for all Supabase features including magic-link auth and data queries.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Magic-link auth setup ────────────────────────────────────────────────────
# In your Supabase dashboard → Authentication → URL Configuration:
#   Site URL:             https://your-domain.com
#   Redirect URLs (add):  https://your-domain.com/auth/callback
#                         http://localhost:3000/auth/callback  (for local dev)
#
# No additional env vars are required — emailRedirectTo is derived from
# window.location.origin at runtime so it works in both dev and production.

# ── Scraping / cron ──────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-your-key-here
CRON_SECRET=a-long-random-secret-string
